{
  "name": "CargoFlow - Tracking Webhook",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "shippo-tracking-webhook",
        "responseMode": "lastNode",
        "options": {}
      },
      "id": "webhook-trigger",
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1.1,
      "position": [240, 400],
      "webhookId": "shippo-tracking-webhook"
    },
    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body;\nconst event = body.event || body;\n\n// Shippo webhook payload 结构\nconst trackingStatus = event.data || event.tracking_status || event;\nconst trackingNumber = trackingStatus.tracking_number;\nconst status = trackingStatus.status;\nconst substatus = trackingStatus.substatus?.text || '';\nconst carrier = trackingStatus.carrier;\nconst eta = trackingStatus.eta;\n\nif (!trackingNumber) {\n  throw new Error('Webhook payload 缺少 tracking_number');\n}\n\nreturn {\n  trackingNumber,\n  status,\n  substatus,\n  carrier,\n  eta,\n  trackingHistory: trackingStatus.tracking_history || [],\n  location: trackingStatus.location || {},\n  rawPayload: event\n};"
      },
      "id": "parse-webhook",
      "name": "Parse Webhook",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [460, 400]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT id, status, from_address, to_address, tracking_number FROM demo_shipments WHERE tracking_number = '{{ $json.trackingNumber }}' LIMIT 1;",
        "options": {}
      },
      "id": "find-shipment",
      "name": "Find Shipment",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.4,
      "position": [680, 400],
      "credentials": {
        "postgres": {
          "id": "postgres-credentials",
          "name": "PostgreSQL account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const shipment = $input.first().json;\nconst webhook = $('Parse Webhook').first().json;\n\nif (!shipment || !shipment.id) {\n  // 订单不存在，记录日志但不报错\n  return {\n    shipmentFound: false,\n    trackingNumber: webhook.trackingNumber,\n    status: webhook.status,\n    message: '订单未找到，可能是外部 tracking number'\n  };\n}\n\nreturn {\n  shipmentFound: true,\n  shipmentId: shipment.id,\n  trackingNumber: webhook.trackingNumber,\n  newStatus: webhook.status,\n  substatus: webhook.substatus,\n  oldStatus: shipment.status,\n  fromAddress: shipment.from_address,\n  toAddress: shipment.to_address\n};"
      },
      "id": "check-shipment",
      "name": "Check Shipment",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [900, 400]
    },
    {
      "parameters": {
        "conditions": {
          "boolean": [
            {
              "value1": "={{ $json.shipmentFound }}",
              "value2": true
            }
          ]
        }
      },
      "id": "if-shipment-found",
      "name": "If Shipment Found",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [1120, 400]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "UPDATE demo_shipments SET tracking_status = '{{ $json.newStatus }}', status = CASE WHEN '{{ $json.newStatus }}' = 'DELIVERED' THEN 'delivered' WHEN '{{ $json.newStatus }}' IN ('TRANSIT', 'OUT_FOR_DELIVERY') THEN 'in_transit' ELSE status END, updated_at = NOW() WHERE id = {{ $json.shipmentId }} RETURNING *;",
        "options": {}
      },
      "id": "update-shipment-status",
      "name": "Update Shipment Status",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.4,
      "position": [1340, 300],
      "credentials": {
        "postgres": {
          "id": "postgres-credentials",
          "name": "PostgreSQL account"
        }
      }
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO automation_logs (shipment_id, action_type, details, created_at) VALUES ({{ $json.id }}, 'tracking_updated', '{\"status\": \"{{ $('Check Shipment').first().json.newStatus }}\", \"substatus\": \"{{ $('Check Shipment').first().json.substatus }}\"}'::jsonb, NOW());",
        "options": {}
      },
      "id": "log-tracking-update",
      "name": "Log Tracking Update",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.4,
      "position": [1560, 300],
      "credentials": {
        "postgres": {
          "id": "postgres-credentials",
          "name": "PostgreSQL account"
        }
      }
    },
    {
      "parameters": {
        "conditions": {
          "string": [
            {
              "value1": "={{ $('Check Shipment').first().json.newStatus }}",
              "operation": "equals",
              "value2": "DELIVERED"
            }
          ]
        }
      },
      "id": "if-delivered",
      "name": "If Delivered",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
