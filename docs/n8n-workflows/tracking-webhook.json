            { "name": "subject", "value": "Your package has been delivered!" },
            { "name": "html", "value": "={{ '<h2>Package Delivered</h2><p>Hi ' + $('Check Shipment').first().json.senderName + ',</p><p>Tracking: <strong>' + $('Check Shipment').first().json.trackingNumber + '</strong> has been delivered to ' + $('Check Shipment').first().json.toAddress + '.</p><p>Thank you for using CargoFlow!</p>' }}" }
          ]
        },
        "options": {}
      },
