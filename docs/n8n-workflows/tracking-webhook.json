        "query": "INSERT INTO automation_logs (shipment_id, action_type, details, success, created_at) VALUES ({{ $('Update Shipment Status').first().json.id }}, 'email_delivered_sent', '{\"email\": \"{{ $('Check Shipment').first().json.senderEmail }}\", \"tracking_number\": \"{{ $('Check Shipment').first().json.trackingNumber }}\"}'::jsonb, true, NOW());",
        "options": {}
