{
  "name": "CargoFlow - Payment Processing",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "stripe-payment-webhook",
        "responseMode": "lastNode",
        "options": {}
      },
      "id": "webhook-trigger",
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1.1,
      "position": [
        240,
        300
      ],
      "webhookId": "stripe-payment-webhook"
    },
    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body;\nconst event = body;\nconst eventType = event.type;\nconst paymentIntent = event.data?.object || {};\n\nif (eventType !== 'payment_intent.succeeded') {\n  return { shouldProcess: false, eventType };\n}\n\nconst paymentId = paymentIntent.id;\nconst amount = paymentIntent.amount / 100;\nconst currency = (paymentIntent.currency || 'usd').toUpperCase();\nconst metadata = paymentIntent.metadata || {};\nconst shipmentId = parseInt(metadata.shipment_id);\nconst customerEmail = paymentIntent.receipt_email || metadata.customer_email || '';\n\nif (!shipmentId) throw new Error('metadata 缺少 shipment_id');\n\nreturn { shouldProcess: true, paymentId, amount, currency, shipmentId, customerEmail };"
      },
      "id": "parse-webhook",
      "name": "Parse Webhook",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        460,
        300
      ]
    },
    {
      "parameters": {
        "conditions": {
          "boolean": [
            {
              "value1": "={{ $json.shouldProcess }}",
              "value2": true
            }
          ]
        }
      },
      "id": "should-process",
      "name": "Should Process",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        680,
        300
      ]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT id, from_address, to_address, weight, carrier, service_name, quote_amount, sender_email, sender_phone, tracking_number FROM demo_shipments WHERE id = {{ $json.shipmentId }} LIMIT 1;",
        "options": {}
      },
      "id": "get-shipment",
      "name": "Get Shipment",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.4,
      "position": [
        900,
        200
      ],
      "credentials": {
        "postgres": {
          "id": "postgres-credentials",
          "name": "PostgreSQL account"
        }
      }
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "UPDATE demo_shipments SET status = 'paid', stripe_payment_id = '{{ $('Parse Webhook').first().json.paymentId }}', paid_at = NOW(), updated_at = NOW() WHERE id = {{ $json.id }} RETURNING *;",
        "options": {}
      },
      "id": "update-paid",
      "name": "Update Paid",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.4,
      "position": [
        1120,
        200
      ],
      "credentials": {
        "postgres": {
          "id": "postgres-credentials",
          "name": "PostgreSQL account"
        }
      }
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO automation_logs (shipment_id, action_type, details, created_at) VALUES ({{ $json.id }}, 'payment_succeeded', '{\"payment_id\": \"{{ $('Parse Webhook').first().json.paymentId }}\", \"amount\": {{ $('Parse Webhook').first().json.amount }}, \"currency\": \"{{ $('Parse Webhook').first().json.currency }}\"}'::jsonb, NOW());",
        "options": {}
      },
      "id": "log-payment",
      "name": "Log Payment",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.4,
      "position": [
        1340,
        200
      ],
      "credentials": {
        "postgres": {
          "id": "postgres-credentials",
          "name": "PostgreSQL account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const shipment = $('Get Shipment').first().json;\nconst payment = $('Parse Webhook').first().json;\nconst toEmail = payment.customerEmail || shipment.sender_email;\n\nif (!toEmail) return { skipEmail: true };\n\nreturn {\n  skipEmail: false,\n  toEmail,\n  subject: `CargoFlow 支付确认 - 订单 #${shipment.id}`,\n  htmlBody: `\n<div style=\"font-family:sans-serif;max-width:600px;margin:0 auto\">\n  <h2 style=\"color:#2563eb\">🚚 CargoFlow 支付确认</h2>\n  <p>您好！您的运费已支付成功。</p>\n  <table style=\"width:100%;border-collapse:collapse;margin:16px 0\">\n    <tr><td style=\"padding:8px;background:#f3f4f6;font-weight:bold\">订单编号</td><td style=\"padding:8px\">#${shipment.id}</td></tr>\n    <tr><td style=\"padding:8px;background:#f3f4f6;font-weight:bold\">路线</td><td style=\"padding:8px\">${shipment.from_address} → ${shipment.to_address}</td></tr>\n    <tr><td style=\"padding:8px;background:#f3f4f6;font-weight:bold\">承运商</td><td style=\"padding:8px\">${shipment.carrier} ${shipment.service_name}</td></tr>\n    <tr><td style=\"padding:8px;background:#f3f4f6;font-weight:bold\">支付金额</td><td style=\"padding:8px;color:#16a34a;font-weight:bold\">$${payment.amount} ${payment.currency}</td></tr>\n  </table>\n  <p style=\"color:#6b7280;font-size:12px\">感谢使用 CargoFlow 物流服务</p>\n</div>\n`\n};"
      },
      "id": "build-email",
      "name": "Build Email",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1560,
        200
      ]
    },
    {
      "parameters": {
        "conditions": {
          "boolean": [
            {
              "value1": "={{ !$json.skipEmail }}",
              "value2": true
            }
          ]
        }
      },
      "id": "has-email",
      "name": "Has Email",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        1780,
        200
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.resend.com/emails",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "contentType": "raw",
        "rawContentType": "application/json",
        "body": "={{ JSON.stringify({ from: $env.RESEND_FROM_EMAIL || 'onboarding@resend.dev', to: [$json.toEmail], subject: $json.subject, html: $json.htmlBody }) }}",
        "options": {}
      },
      "id": "send-email",
      "name": "Resend - Send Email",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        2000,
