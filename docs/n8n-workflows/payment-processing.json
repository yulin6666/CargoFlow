    {
      "parameters": {
        "jsCode": "const shipment = $('Get Shipment').first().json;\nconst payment = $('Parse Webhook').first().json;\n\nreturn {\n  contactEmail: payment.customerEmail || shipment.sender_email || `demo_${shipment.id}@cargoflow.test`,\n  contactName: shipment.sender_name || `Customer #${shipment.id}`,\n  contactPhone: shipment.sender_phone || '',\n  orderShipmentId: shipment.id,\n  orderAmount: payment.amount,\n  orderRoute: `${shipment.from_address} → ${shipment.to_address}`,\n  orderCarrier: `${shipment.carrier || ''} ${shipment.service_name || ''}`.trim(),\n  orderDate: new Date().toISOString().split('T')[0]\n};"
      },
      "id": "build-airtable-data",
      "name": "Build Airtable Data",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1560,
        340
