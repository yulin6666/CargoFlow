          "name": "Resend API Key"
        }
      }
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO automation_logs (shipment_id, action_type, details, success, created_at) VALUES ({{ $('Get Shipment').first().json.id }}, 'email_payment_confirmation', '{\"to\": \"{{ $('Build Email').first().json.toEmail }}\", \"subject\": \"支付确认\"}'::jsonb, true, NOW());",
        "options": {}
      },
      "id": "log-email",
