FROM n8nio/n8n:latest

# 设置工作目录
WORKDIR /home/node

# 复制 workflow 配置文件
COPY docs/n8n-workflows /home/node/.n8n/workflows

# 设置必要的环境变量（从 Railway 环境变量中读取）
ENV N8N_HOST=${N8N_HOST}
ENV N8N_PORT=5678
ENV N8N_PROTOCOL=https
ENV WEBHOOK_URL=${WEBHOOK_URL}
ENV VUE_APP_URL_BASE_API=${VUE_APP_URL_BASE_API}
ENV N8N_BASIC_AUTH_ACTIVE=true
ENV N8N_BASIC_AUTH_USER=${N8N_BASIC_AUTH_USER}
ENV N8N_BASIC_AUTH_PASSWORD=${N8N_BASIC_AUTH_PASSWORD}

# 暴露端口
EXPOSE 5678

# 启动 n8n
CMD ["n8n", "start"]
